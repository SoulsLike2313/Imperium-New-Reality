{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "important_six.owner_question.v0_1",
  "title": "Owner Question Record",
  "type": "object",
  "required": [
    "question_id",
    "organ",
    "severity",
    "question",
    "required_decision",
    "status",
    "created_at_utc"
  ],
  "properties": {
    "question_id": { "type": "string", "minLength": 4 },
    "organ": { "type": "string", "minLength": 2 },
    "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
    "question": { "type": "string", "minLength": 4 },
    "evidence": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "required_decision": { "type": "string", "minLength": 3 },
    "status": { "type": "string", "enum": ["OPEN", "ANSWERED", "BLOCKED", "DEFERRED"] },
    "owner_note_ru": { "type": "string" },
    "decision": { "type": "string" },
    "created_at_utc": { "type": "string", "minLength": 20 },
    "updated_at_utc": { "type": "string" }
  },
  "additionalProperties": true
}
