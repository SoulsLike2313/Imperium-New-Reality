{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Requirement Evidence Matrix",
  "type": "object",
  "required": [
    "task_id",
    "requirements"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "requirements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "requirement_id",
          "status",
          "evidence_paths"
        ],
        "properties": {
          "requirement_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "DONE",
              "BLOCKED",
              "NOT_DONE"
            ]
          },
          "evidence_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}

