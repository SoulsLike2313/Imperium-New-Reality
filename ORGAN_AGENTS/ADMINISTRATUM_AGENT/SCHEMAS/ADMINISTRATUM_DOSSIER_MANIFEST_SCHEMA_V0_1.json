{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "imperium.administratum.dossier_manifest.v0_1",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "run_id",
    "created_at_utc",
    "git_truth",
    "verdict",
    "files",
    "owner_pdf"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "created_at_utc": {
      "type": "string"
    },
    "git_truth": {
      "type": "object",
      "required": [
        "head",
        "branch",
        "dirty"
      ],
      "properties": {
        "head": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "dirty": {
          "type": "boolean"
        }
      }
    },
    "verdict": {
      "type": "string",
      "enum": [
        "PASS",
        "WARN",
        "BLOCKED",
        "FAIL"
      ]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "unverified": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256",
          "bytes"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "sha256": {
            "type": "string"
          },
          "bytes": {
            "type": "integer"
          }
        }
      }
    },
    "owner_pdf": {
      "type": "object",
      "required": [
        "generated",
        "language",
        "backend"
      ],
      "properties": {
        "generated": {
          "type": "boolean"
        },
        "language": {
          "type": "string"
        },
        "backend": {
          "type": "string"
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "default_zip_policy": {
          "type": "string"
        },
        "optional_external_render_only": {
          "type": "boolean"
        }
      }
    }
  }
}
