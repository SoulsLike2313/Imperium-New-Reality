{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Officio Response Checker Report V0.1",
  "type": "object",
  "required": [
    "status",
    "generated_at_utc",
    "items"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "PASS",
        "WARN",
        "FAIL"
      ]
    },
    "generated_at_utc": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "file",
          "status",
          "violations",
          "recommended_correction",
          "limitations"
        ],
        "properties": {
          "file": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "WARN",
              "FAIL"
            ]
          },
          "violations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "recommended_correction": {
            "type": "string"
          },
          "limitations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
