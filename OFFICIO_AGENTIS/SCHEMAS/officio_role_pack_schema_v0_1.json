{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Officio Role Pack V0.1",
  "type": "object",
  "required": [
    "role_id",
    "mission",
    "owner_facing_language",
    "technical_artifact_language",
    "live_progress_style",
    "final_response_format",
    "required_acks",
    "forbidden_actions",
    "stop_conditions",
    "violation_policy",
    "allowed_technical_english_fields",
    "response_length_guidance"
  ],
  "properties": {
    "role_id": {
      "type": "string",
      "minLength": 1
    },
    "mission": {
      "type": "string",
      "minLength": 1
    },
    "owner_facing_language": {
      "type": "string",
      "enum": [
        "ru"
      ]
    },
    "technical_artifact_language": {
      "type": "string",
      "enum": [
        "en_safe"
      ]
    },
    "live_progress_style": {
      "type": "string"
    },
    "final_response_format": {
      "type": "string"
    },
    "required_acks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "forbidden_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "violation_policy": {
      "type": "object"
    },
    "allowed_technical_english_fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "response_length_guidance": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
