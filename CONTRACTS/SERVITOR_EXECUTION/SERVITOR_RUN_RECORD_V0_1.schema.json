{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "IMPERIUM_NEW_GENERATION/CONTRACTS/SERVITOR_EXECUTION/SERVITOR_RUN_RECORD_V0_1.schema.json",
  "title": "Servitor Run Record V0.1",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "session_id",
    "task_id",
    "run_index",
    "status",
    "checks",
    "failure_classification",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1"
    },
    "run_id": {
      "type": "string",
      "minLength": 3
    },
    "session_id": {
      "type": "string",
      "minLength": 3
    },
    "task_id": {
      "type": "string",
      "minLength": 3
    },
    "run_index": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "PLANNED",
        "STARTED",
        "CHECKED",
        "FAILED_CLASSIFIED",
        "RERUN_PLANNED",
        "PASSED_WITH_EVIDENCE",
        "BLOCKED"
      ]
    },
    "started_at_utc": {
      "type": "string"
    },
    "finished_at_utc": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "check_id",
          "status"
        ],
        "properties": {
          "check_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PASS",
              "WARN",
              "FAIL",
              "BLOCK"
            ]
          },
          "detail": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "failure_classification": {
      "type": "string",
      "enum": [
        "NONE",
        "TASK_ARCHITECTURE_FAILURE",
        "SCOPE_AMBIGUITY",
        "SKILL_GAP",
        "TOOL_MISSING",
        "VALIDATOR_FAILURE",
        "VISUAL_MISMATCH",
        "FAKE_GREEN_RISK",
        "OWNER_DECISION_REQUIRED",
        "FOUNDATION_LIMITATION"
      ]
    },
    "explanation_ru": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
