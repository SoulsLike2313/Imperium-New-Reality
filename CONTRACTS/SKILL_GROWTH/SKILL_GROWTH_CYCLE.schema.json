{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "IMPERIUM_NEW_GENERATION/CONTRACTS/SKILL_GROWTH/SKILL_GROWTH_CYCLE.schema.json",
  "title": "Skill Growth Cycle V0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "cycle_id",
    "task_id",
    "mode",
    "foundation_only",
    "production_learning_enabled",
    "automatic_live_agent_mutation",
    "skill_gaps",
    "lessons",
    "skill_update_proposals",
    "validator_recommendations",
    "forbidden_claims",
    "generated_at_utc"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1"
    },
    "cycle_id": {
      "type": "string",
      "minLength": 3
    },
    "task_id": {
      "type": "string",
      "minLength": 3
    },
    "mode": {
      "type": "string",
      "enum": [
        "FOUNDATION_ONLY",
        "ADVISORY_ONLY",
        "PRODUCTION"
      ]
    },
    "foundation_only": {
      "type": "boolean"
    },
    "production_learning_enabled": {
      "type": "boolean"
    },
    "automatic_live_agent_mutation": {
      "type": "boolean"
    },
    "skill_gaps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "record_id",
          "source_failure_type",
          "source_rerun_decision"
        ],
        "properties": {
          "record_id": {
            "type": "string"
          },
          "source_failure_type": {
            "type": "string"
          },
          "source_rerun_decision": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "lessons": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "lesson_id",
          "linked_skill_gap_id",
          "proof_status",
          "confidence"
        ],
        "properties": {
          "lesson_id": {
            "type": "string"
          },
          "linked_skill_gap_id": {
            "type": "string"
          },
          "proof_status": {
            "type": "string"
          },
          "confidence": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "skill_update_proposals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "proposal_id",
          "mutating_live_agents",
          "proposal_effect"
        ],
        "properties": {
          "proposal_id": {
            "type": "string"
          },
          "mutating_live_agents": {
            "type": "boolean"
          },
          "proposal_effect": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "validator_recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "recommendation_id",
          "advisory_only",
          "proof_status"
        ],
        "properties": {
          "recommendation_id": {
            "type": "string"
          },
          "advisory_only": {
            "type": "boolean"
          },
          "proof_status": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "forbidden_claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 20
    }
  }
}
