{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "IMPERIUM_NEW_GENERATION/CONTRACTS/ASTRONOMICON/TASK_FORMATION_REQUEST_V0_1.schema.json",
  "title": "NewGen Astronomicon Task Formation Request V0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "owner_intent",
    "contour",
    "constraints",
    "requested_outputs"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1"
    },
    "request_id": {
      "type": "string",
      "minLength": 5
    },
    "owner_intent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_text",
        "language"
      ],
      "properties": {
        "raw_text": {
          "type": "string",
          "minLength": 10
        },
        "language": {
          "type": "string",
          "enum": [
            "RU",
            "EN",
            "MIXED",
            "UNKNOWN"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 3
        }
      }
    },
    "contour": {
      "type": "string",
      "enum": [
        "PC",
        "VM2",
        "VM3",
        "UNKNOWN"
      ]
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_paths",
        "forbidden_paths",
        "auto_commit_push",
        "no_live_runtime_claim"
      ],
      "properties": {
        "allowed_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "forbidden_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "auto_commit_push": {
          "type": "boolean"
        },
        "no_live_runtime_claim": {
          "type": "boolean"
        }
      }
    },
    "requested_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "task_kernel_draft",
          "stage_map_preview",
          "servitor_start_block",
          "owner_questions"
        ]
      }
    },
    "owner_questions_policy": {
      "type": "string"
    },
    "task_hints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "suggested_task_id": {
          "type": "string"
        },
        "priority_tier": {
          "type": "string",
          "enum": [
            "P0",
            "P1",
            "P2",
            "P3"
          ]
        },
        "stage_depth": {
          "type": "integer",
          "minimum": 2,
          "maximum": 12
        }
      }
    }
  }
}
