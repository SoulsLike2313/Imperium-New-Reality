{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TOOL_CAPABILITY_RECEIPT",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "task_id",
    "tool_slug",
    "capability_name",
    "outcome_state",
    "evidence_paths",
    "decision_id",
    "execution_mode",
    "run_command",
    "run_result",
    "no_install_performed",
    "foundation_only",
    "created_at_utc"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "receipt_id": {
      "type": "string",
      "pattern": "^TCAP-[0-9]{3}$"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "tool_slug": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-/]+$"
    },
    "capability_name": {
      "type": "string",
      "minLength": 1
    },
    "outcome_state": {
      "type": "string",
      "enum": [
        "CANDIDATE_ONLY",
        "AVAILABLE_ON_HOST_UNVERIFIED_FOR_IMPERIUM",
        "AVAILABLE_ON_HOST_VERIFIED_BASIC",
        "DEFERRED_NEEDS_OWNER",
        "DEFERRED_NEEDS_ADMISSION_TASK",
        "BLOCKED_BY_RISK",
        "APPROVED_FOR_FUTURE_INSTALL_TASK",
        "APPROVED_FOR_READ_ONLY_USE",
        "INSTALLED_AND_REGISTERED"
      ]
    },
    "evidence_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "decision_id": {
      "type": "string",
      "pattern": "^TDEC-[0-9]{3}$"
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "CANDIDATE_REGISTRY_ONLY",
        "READ_ONLY_HOST_CHECK",
        "INSTALL_TASK",
        "POST_INSTALL_USE"
      ]
    },
    "run_command": {
      "type": "string"
    },
    "run_result": {
      "type": "string",
      "enum": [
        "NOT_RUN",
        "PASS",
        "WARN",
        "FAIL"
      ]
    },
    "no_install_performed": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    },
    "foundation_only": {
      "type": "boolean"
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    }
  }
}
