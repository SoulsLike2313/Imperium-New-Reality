    "life_zone_path": {"type": "string", "minLength": 1},
    "primary_duty": {"type": "string", "minLength": 1},
    "status": {"type": "string", "minLength": 1},
    "owned_metrics": {"type": "array"},
    "owned_matrices": {"type": "array"},
    "validators": {"type": "array"},
    "warnings": {"type": "array"}
  },
  "additionalProperties": true
}
