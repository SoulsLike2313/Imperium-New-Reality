{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Core File Ownership Entry V0.1",
  "type": "object",
  "required": ["schema_version", "path", "classification", "owner_organ", "evidence", "confidence"],
  "properties": {
    "schema_version": {"type": "string"},
    "path": {"type": "string", "minLength": 1},
    "classification": {"type": "string", "minLength": 1},
    "owner_organ": {"type": "string", "minLength": 1},
    "evidence": {"type": "array"},
    "confidence": {"type": "string", "enum": ["HIGH", "MEDIUM", "LOW", "UNKNOWN_WITH_REASON"]},
    "next_action": {"type": "string"}
  },
  "additionalProperties": true
}
