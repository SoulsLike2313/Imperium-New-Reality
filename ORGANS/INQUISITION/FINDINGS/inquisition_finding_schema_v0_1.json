{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "inquisition_finding_schema_v0_1",
  "title": "Inquisition Finding Schema V0.1",
  "type": "object",
  "required": [
    "finding_id",
    "severity",
    "risk_type",
    "path",
    "evidence",
    "why_it_matters",
    "recommended_next_action"
  ],
  "properties": {
    "finding_id": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": [
        "CRITICAL",
        "WARNING",
        "INFO"
      ]
    },
    "risk_type": {
      "type": "string"
    },
    "path": {
      "type": "string"
    },
    "organ": {
      "type": "string"
    },
    "evidence": {
      "type": "string"
    },
    "why_it_matters": {
      "type": "string"
    },
    "recommended_next_action": {
      "type": "string"
    },
    "blocking_gate": {
      "type": "boolean"
    },
    "safe_to_ignore_until": {
      "type": "string"
    },
    "related_tool_id": {
      "type": "string"
    },
    "related_atlas_entity": {
      "type": "string"
    }
  }
}