{
  "policy_id": "inquisition.runtime_retention_policy.v0_1",
  "version": "0.1.0",
  "default_ttl_hours": 48,
  "source_repo_delete_default": false,
  "local_runtime_action_default": "quarantine",
  "allowed_local_roots": [
    "E:/_LOCAL_HANDOFF/SERVITOR_OUTPUTS",
    "E:/_LOCAL_HANDOFF/DEBUG_PACKS",
    "E:/_LOCAL_HANDOFF/PATCH_BACKUPS",
    "E:/_LOCAL_HANDOFF/QUARANTINE",
    "E:/IMPERIUM_LOCAL_HANDOFF/WARP_RUNS"
  ],
  "runtime_output_patterns": [
    "MEGA_PLAYWRIGHT_AUDIT_*",
    "DATA_ATLAS_SCREENSHOTS*",
    "INQUISITION_HYGIENE_AUDIT_*",
    "MECHANICUS_OPERATIONAL_POWER_*",
    "MOJIBAKE_*",
    "SANCTUM_ATLAS_FULL_CAPTURE_*",
    "*.tmp",
    "*.log"
  ],
  "source_generated_cache_patterns": [
    "__pycache__",
    "*.pyc",
    "*.pyo",
    ".pytest_cache",
    ".mypy_cache",
    ".ruff_cache"
  ],
  "non_destructive_first": true,
  "notes_ru": "TTL-48 применяется к локальным runtime/evidence outputs. Source repo очищается только отдельными owner-reviewed patches."
}
