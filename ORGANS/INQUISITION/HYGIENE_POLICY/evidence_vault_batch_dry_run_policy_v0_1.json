    "EVIDENCE_VAULT_BATCH_001_DRY_RUN_SHA256SUMS.txt",
    "EVIDENCE_VAULT_BATCH_001_DRY_RUN_STAGING_LAYOUT_PREVIEW.json",
    "EVIDENCE_VAULT_BATCH_001_DRY_RUN.sqlite",
    "EVIDENCE_VAULT_BATCH_001_DRY_RUN_VISUAL_PROOF_DASHBOARD.html"
  ],
  "owner_gate": "PASS authorizes execution-patch preparation only; it does not authorize packing, moving, or deleting source."
}
