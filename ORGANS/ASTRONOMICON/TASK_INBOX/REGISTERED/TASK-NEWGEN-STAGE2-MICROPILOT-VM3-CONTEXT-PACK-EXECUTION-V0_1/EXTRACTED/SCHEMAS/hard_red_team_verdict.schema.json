{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hard Red Team Verdict",
  "type": "object",
  "required": [
    "task_id",
    "generated_at_utc",
    "checks",
    "caps_triggered",
    "downgrades",
    "verdict"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "checks": {
      "type": "object"
    },
    "caps_triggered": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "downgrades": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verdict": {
      "type": "string"
    }
  }
}
