{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "task_id",
    "moved_files",
    "no_deletion",
    "ancient_mutation"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "moved_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_path",
          "target_path",
          "classification",
          "reason",
          "sha256"
        ]
      }
    },
    "no_deletion": {
      "type": "boolean"
    },
    "ancient_mutation": {
      "type": "boolean"
    }
  }
}
