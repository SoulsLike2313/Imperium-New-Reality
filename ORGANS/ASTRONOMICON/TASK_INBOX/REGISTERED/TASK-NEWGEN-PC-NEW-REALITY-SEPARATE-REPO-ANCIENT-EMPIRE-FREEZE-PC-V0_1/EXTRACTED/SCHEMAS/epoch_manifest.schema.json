{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Epoch Manifest",
  "type": "object",
  "required": [
    "epoch",
    "active_root",
    "source_epoch",
    "ancient_reference",
    "servitor_scope"
  ],
  "properties": {
    "epoch": {
      "const": "NEW_REALITY"
    },
    "active_root": {
      "type": "string"
    },
    "source_epoch": {
      "const": "ANCIENT_EMPIRE"
    },
    "ancient_reference": {
      "type": "object"
    },
    "servitor_scope": {
      "type": "object"
    },
    "created_utc": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
