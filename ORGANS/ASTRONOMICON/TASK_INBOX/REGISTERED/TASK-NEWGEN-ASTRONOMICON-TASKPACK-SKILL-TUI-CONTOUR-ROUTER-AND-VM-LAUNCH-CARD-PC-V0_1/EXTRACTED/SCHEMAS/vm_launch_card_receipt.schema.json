{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VM Launch Card Receipt",
  "type": "object",
  "required": [
    "contour",
    "task_id",
    "terminal_attempted",
    "terminal_opened_or_explained",
    "copy_message",
    "verdict"
  ],
  "properties": {
    "contour": {
      "enum": [
        "VM3",
        "VM2",
        "PC"
      ]
    },
    "task_id": {
      "type": "string"
    },
    "terminal_attempted": {
      "type": "boolean"
    },
    "terminal_opened_or_explained": {
      "type": "boolean"
    },
    "copy_message": {
      "const": "start task"
    },
    "verdict": {
      "type": "string"
    }
  }
}
