{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Astronomicon Task Route Packet V0.1",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "target_contour",
    "execution_mode",
    "primary_organ",
    "support_organs",
    "phases",
    "required_receipts",
    "stop_conditions",
    "forbidden_actions",
    "not_proven_boundary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "astronomicon.task_route_packet.v0_1"
    },
    "task_id": {
      "type": "string",
      "pattern": "^TASK-"
    },
    "target_contour": {
      "type": "string"
    },
    "execution_mode": {
      "type": "string",
      "enum": ["SERVITOR", "WARP_TEMPLATE_ONLY"]
    },
    "primary_organ": {
      "type": "string"
    },
    "support_organs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["phase_id", "goal", "deliverables"],
        "properties": {
          "phase_id": {
            "type": "string"
          },
          "goal": {
            "type": "string"
          },
          "deliverables": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        },
        "additionalProperties": false
      }
    },
    "required_receipts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "stop_conditions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "forbidden_actions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "not_proven_boundary": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
