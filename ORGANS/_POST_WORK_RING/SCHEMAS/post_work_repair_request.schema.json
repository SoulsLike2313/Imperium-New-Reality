{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Post Work Repair Request V0.2",
  "type": "object",
  "required": ["schema_version", "task_id", "repair_request_id", "blocked_verdict", "owner_organ", "requested_repairs", "status"],
  "properties": {
    "schema_version": {"type": "string"},
    "task_id": {"type": "string", "minLength": 1},
    "repair_request_id": {"type": "string", "minLength": 1},
    "created_at_utc": {"type": "string"},
    "blocked_verdict": {"type": "string", "minLength": 1},
    "owner_organ": {"type": "string", "minLength": 1},
    "trigger_issue": {"type": "string"},
    "requested_repairs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["issue_id", "path", "repair_action"],
        "properties": {
          "issue_id": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "repair_action": {"type": "string", "minLength": 1}
        },
        "additionalProperties": true
      }
    },
    "status": {"type": "string", "minLength": 1}
  },
  "additionalProperties": true
}
