{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Post Work Organ Ring Receipt V0.2",
  "type": "object",
  "required": ["schema_version", "task_id", "organ_receipts"],
  "properties": {
    "schema_version": {"type": "string"},
    "task_id": {"type": "string", "minLength": 1},
    "created_at_utc": {"type": "string"},
    "required_organs_source": {"type": "string"},
    "organ_receipts": {
      "type": "array",
      "minItems": 9,
      "items": {
        "type": "object",
        "required": ["organ_id", "task_id", "status", "owned_checks", "evidence_paths", "learned_rules"],
        "properties": {
          "organ_id": {"type": "string", "minLength": 1},
          "task_id": {"type": "string", "minLength": 1},
          "status": {
            "type": "string",
            "enum": ["IMPLEMENTED", "IMPLEMENTED_WITH_WARNINGS", "NOT_YET_IMPLEMENTED", "BLOCK"]
          },
          "owned_checks": {"type": "array"},
          "evidence_paths": {"type": "array"},
          "learned_rules": {"type": "array"},
          "limitation_reason": {"type": "string"},
          "next_task_route": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "ring_verdict": {"type": "string"}
  },
  "additionalProperties": true
}
