{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "imperium.tool_passport.v0_2",
  "title": "Imperium Tool Passport v0_2",
  "description": "Mandatory passport for every tool living under ORGANS/. Declares identity, ownership, validators, exec mode, and observability. See MECHANICUS_PASSPORT_DOCTRINE_V0_2_RU.md.",
  "type": "object",
  "required": [
    "schema_id",
    "tool_id",
    "name",
    "version",
    "owner_organ",
    "lang",
    "validators",
    "exec_mode",
    "owner_gated"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_id": {
      "type": "string",
      "const": "imperium.tool_passport.v0_2"
    },
    "tool_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "Unique snake_case identifier across the repo."
    },
    "name": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+(_[0-9]+)*$"
    },
    "owner_organ": {
      "type": "string",
      "enum": [
        "MECHANICUS",
        "IMPERIAL_IDE",
        "DOCTRINARIUM",
        "OFFICIO_AGENTIS",
        "SPECULUM",
        "INQUISITOR",
        "OBSERVATORIUM",
        "_CORE_GOVERNANCE"
      ]
    },
    "lang": {
      "type": "string",
      "enum": [
        "python", "rust", "typescript", "javascript",
        "powershell", "css", "html", "markdown", "mixed"
      ]
    },
    "build_system": {
      "type": "string",
      "enum": ["stdlib", "cargo", "npm", "pnpm", "yarn", "pwsh", "none", "mixed"]
    },
    "validators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "exec"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "exec": { "type": "string", "minLength": 1, "description": "shell command; supports {repo} and {tool_path} placeholders" },
          "timeout_seconds": { "type": "number", "minimum": 1, "maximum": 300, "default": 10 }
        }
      }
    },
    "io_contract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "input_schema":  { "type": "string", "description": "relative path to JSON schema for inputs" },
        "output_schema": { "type": "string", "description": "relative path to JSON schema for outputs" },
        "report_schema": { "type": "string", "description": "relative path to JSON schema for reports/receipts" }
      }
    },
    "observability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stdout":     { "type": "string", "enum": ["rich", "plain", "json", "none"] },
        "metrics":    { "type": "array", "items": { "type": "string" } },
        "log_paths":  { "type": "array", "items": { "type": "string" } }
      }
    },
    "exec_mode": {
      "type": "string",
      "enum": ["static", "sim", "paper", "shadow", "live"]
    },
    "owner_gated": {
      "type": "boolean",
      "description": "true => never auto-run; require explicit owner approval"
    },
    "capability_tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "depends_on": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
      "description": "tool_ids this tool depends on at runtime"
    },
    "doctrine_ref": {
      "type": "string",
      "description": "relative path to the controlling doctrine document"
    },
    "tool_path": {
      "type": "string",
      "description": "relative path from repo root to the tool's main executable file"
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
