{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Post Work Bundle Index Card V0.2",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "bundle_id",
    "primary_report_path",
    "bundle_manifest_path",
    "receipt_index_path",
    "file_delta_index_path",
    "organ_ring_receipt_path",
    "github_safe",
    "verdict"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "task_id": {"type": "string", "minLength": 1},
    "bundle_id": {"type": "string", "minLength": 1},
    "primary_report_path": {"type": "string", "minLength": 1},
    "bundle_manifest_path": {"type": "string", "minLength": 1},
    "receipt_index_path": {"type": "string", "minLength": 1},
    "file_delta_index_path": {"type": "string", "minLength": 1},
    "organ_ring_receipt_path": {"type": "string", "minLength": 1},
    "github_safe": {"type": "boolean"},
    "verdict": {"type": "string", "minLength": 1},
    "checker_report_path": {"type": "string"},
    "local_heavy_artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256", "storage_policy", "visibility_policy", "owner_organ", "reason_not_committed"],
        "properties": {
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "minLength": 1},
          "storage_policy": {"type": "string", "minLength": 1},
          "visibility_policy": {"type": "string", "minLength": 1},
          "owner_organ": {"type": "string", "minLength": 1},
          "reason_not_committed": {"type": "string", "minLength": 1}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
