{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Claim Ledger",
  "type": "object",
  "required": ["task_id", "claims"],
  "properties": {
    "task_id": {"type": "string", "minLength": 1},
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "evidence", "verdict"],
        "properties": {
          "claim": {"type": "string"},
          "evidence": {"type": "string"},
          "verdict": {"type": "string"}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
