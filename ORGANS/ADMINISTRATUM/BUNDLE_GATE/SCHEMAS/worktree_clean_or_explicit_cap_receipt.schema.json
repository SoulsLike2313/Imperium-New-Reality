{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Worktree Clean Or Explicit Cap Receipt",
  "type": "object",
  "required": ["task_id"],
  "anyOf": [
    {"required": ["worktree_clean"]},
    {"required": ["caps_triggered"]},
    {"required": ["cap_status"]},
    {"required": ["self_reference_limit"]}
  ],
  "properties": {
    "task_id": {"type": "string", "minLength": 1},
    "worktree_clean": {"type": "boolean"},
    "caps_triggered": {"type": "array"},
    "cap_status": {"type": "string"},
    "self_reference_limit": {"type": "string"}
  },
  "additionalProperties": true
}
