      }
    },
    "receipts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "diffs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "final_verdict": {
      "type": "string"
    },
    "absorption_status": {
      "type": "string"
    }
  },
  "additionalProperties": true
