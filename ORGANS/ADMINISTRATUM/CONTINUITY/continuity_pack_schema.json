{
  "schema_version": "administratum.continuity_pack.schema.v0_3",
  "required_top_level_fields": [
    "schema_version",
    "status",
    "mode",
    "repo_root",
    "task_id",
    "contours",
    "git",
    "included_files",
    "handoff_lines",
    "owner_operational_context",
    "continuity_pass_gates",
    "forbidden_actions"
  ],
  "required_contour_fields": [
    "current_contour",
    "main_repo_candidate",
    "h_repo_candidate",
    "h_workflow_rule",
    "main_direct_patch_allowed"
  ],
  "required_owner_visible_pack_files": [
    "CONTINUITY_MANIFEST.json",
    "CONTINUITY_RECEIPT.json",
    "OWNER_CONTINUITY_SUMMARY_RU.md",
    "LOGOS_PRIME_HANDOFF_SUMMARY_RU.md",
    "NEXT_HANDOFF_CARD.md",
    "H_CONTOUR_OPERATION_PROTOCOL_RU.md",
    "LOGOS_PRIME_BOOT_PROTOCOL_RU.md",
    "NEXT_COMMANDS_H_SAFE_RU.md",
    "OPERATIONAL_GAPS_CAUGHT_RU.md"
  ],
  "forbidden_actions": [
    "commit",
    "push",
    "unsafe_shell",
    "live_llm",
    "real_servitor_execution",
    "live_trading_execution"
  ]
}
