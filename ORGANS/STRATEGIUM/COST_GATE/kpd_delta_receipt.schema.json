{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Strategium KPD Delta Receipt V0.1",
  "type": "object",
  "required": [
    "schema_version",
    "task_id",
    "kpd_before",
    "kpd_after",
    "kpd_delta",
    "verdict",
    "evidence_paths",
    "next_route"
  ],
  "properties": {
    "schema_version": {
      "const": "strategium.kpd_delta_receipt.v0_1"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "kpd_before": {
      "type": "string",
      "minLength": 1
    },
    "kpd_after": {
      "type": "string",
      "minLength": 1
    },
    "kpd_delta": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "minLength": 1
    },
    "evidence_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "next_route": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": true
}
