{
  "schema_id": "imperium.tool_passport.v0_2",
  "tool_id": "cockpit",
  "name": "Imperial IDE Cockpit",
  "version": "v0_1",
  "owner_organ": "IMPERIAL_IDE",
  "lang": "mixed",
  "exec_mode": "live",
  "owner_gated": false,
  "description": "Tauri 2.x desktop IDE: Patch Manager, Warp Zone, Diff Room. Sanctum design system.",
  "validators": [
    {
      "id": "cargo_check",
      "type": "command",
      "command": "cargo check --manifest-path {tool_path}/shell-rs/Cargo.toml",
      "timeout_seconds": 180
    },
    {
      "id": "tsc_check",
      "type": "command",
      "command": "sh -c \"cd {tool_path}/app-ts && pnpm install --frozen-lockfile && pnpm tsc --noEmit\"",
      "timeout_seconds": 120
    }
  ],
  "tech_stack": {
    "backend": "Rust + Tauri 2.x",
    "frontend": "React 18 + TypeScript (strict) + Vite 5",
    "styling": "Sanctum CSS tokens"
  },
  "panels": ["PatchManager", "WarpZone", "DiffRoom"]
}
