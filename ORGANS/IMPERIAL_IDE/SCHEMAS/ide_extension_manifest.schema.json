{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "imperium://imperial_ide/schemas/ide_extension_manifest.v0_1",
  "title": "Imperial IDE Extension Manifest",
  "type": "object",
  "required": [
    "extension_id",
    "status",
    "permissions",
    "panels",
    "commands",
    "tools",
    "risks",
    "validation"
  ],
  "properties": {
    "extension_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "PROVEN",
        "CANDIDATE",
        "MISSING",
        "BLOCKED"
      ]
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "panels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "receipts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
