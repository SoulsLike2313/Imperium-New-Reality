<Window x:Class="ImperialWorkbench.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IMPERIAL IDE :: MECHANICUS WORKBENCH" Height="820" Width="1280"
        Background="{StaticResource VoidBrush}" WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="120"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="28"/>
    </Grid.RowDefinitions>

    <!-- NEBULA HEADER -->
    <Grid Grid.Row="0" Background="{StaticResource NebulaHeaderBrush}">
      <Image Source="nebula_background.png" Stretch="UniformToFill" Opacity="0.55"/>
      <StackPanel VerticalAlignment="Center" Margin="24,0">
        <TextBlock Text="\u2042  IMPERIVM :: MECHANICVS WORKBENCH" Foreground="{StaticResource GoldBrush}"
                   FontSize="26" FontFamily="Trajan Pro, Times New Roman" FontWeight="Bold"/>
        <TextBlock Text="Purple Dark Nebula Metallic Control Shell  \u2014  V0.1"
                   Foreground="{StaticResource ChromeBrush}" FontSize="13" FontFamily="Cascadia Mono"/>
      </StackPanel>
    </Grid>

    <!-- BODY: organ sidebar + capsule rack + log -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="360"/>
      </Grid.ColumnDefinitions>

      <!-- ORGAN PANELS -->
      <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource GoldBrush}" BorderThickness="0,0,1,0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="ORGAN PANELS" Foreground="{StaticResource GoldBrush}" Margin="12,10" FontFamily="Cascadia Mono"/>
          <ListBox x:Name="OrganList" Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextBrush}" Margin="6"/>
        </DockPanel>
      </Border>

      <!-- SERVITOR CAPSULE RACK -->
      <Border Grid.Column="1" Background="{StaticResource PanelRaisedBrush}" Margin="0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="SERVITOR CAPSULE RACK" Foreground="{StaticResource GoldBrush}" Margin="14,12" FontFamily="Cascadia Mono"/>
          <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="14,8">
            <Button Content="DISPATCH (round-robin)" Style="{StaticResource MetalButton}" Click="OnDispatch" Margin="0,0,8,0"/>
            <Button Content="REFRESH" Style="{StaticResource MetalButton}" Click="OnRefresh"/>
          </StackPanel>
          <ItemsControl x:Name="CapsuleRack" Margin="14,4"/>
        </DockPanel>
      </Border>

      <!-- LOG CONSOLE -->
      <Border Grid.Column="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource GoldBrush}" BorderThickness="1,0,0,0">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="COGITATOR LOG" Foreground="{StaticResource GoldBrush}" Margin="12,10" FontFamily="Cascadia Mono"/>
          <TextBox x:Name="LogBox" Background="Transparent" Foreground="{StaticResource TextMutedBrush}" BorderThickness="0"
                   FontFamily="Cascadia Mono" FontSize="11" IsReadOnly="True" TextWrapping="Wrap"
                   VerticalScrollBarVisibility="Auto" Margin="8"/>
        </DockPanel>
      </Border>
    </Grid>

    <!-- STATUS BAR -->
    <Border Grid.Row="2" Background="{StaticResource NebulaColor}">
      <TextBlock x:Name="StatusBar" Text="\u2699 bridge: SAMPLE  \u2502  real-exec: OFF  \u2502  Ave Omnissiah"
                 Foreground="{StaticResource ChromeBrush}" FontFamily="Cascadia Mono" FontSize="11" Margin="12,4"/>
    </Border>
  </Grid>
</Window>
