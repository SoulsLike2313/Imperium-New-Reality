<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Purple Dark Nebula Metallic Imperium palette (mirror of imperium_theme.json) -->
  <Color x:Key="VoidColor">#FF05030B</Color>
  <Color x:Key="PanelColor">#FF0F0A1C</Color>
  <Color x:Key="PanelRaisedColor">#FF171029</Color>
  <Color x:Key="NebulaColor">#FF3A1E5C</Color>
  <Color x:Key="NebulaBrightColor">#FF5B2E8A</Color>
  <Color x:Key="PlasmaColor">#FFB96BFF</Color>
  <Color x:Key="GoldColor">#FFC9A24B</Color>
  <Color x:Key="ChromeColor">#FFD6D6E6</Color>
  <Color x:Key="TextColor">#FFECEAF6</Color>
  <Color x:Key="TextMutedColor">#FF9A93B5</Color>

  <SolidColorBrush x:Key="VoidBrush" Color="{StaticResource VoidColor}"/>
  <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}"/>
  <SolidColorBrush x:Key="PanelRaisedBrush" Color="{StaticResource PanelRaisedColor}"/>
  <SolidColorBrush x:Key="GoldBrush" Color="{StaticResource GoldColor}"/>
  <SolidColorBrush x:Key="ChromeBrush" Color="{StaticResource ChromeColor}"/>
  <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
  <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>

  <!-- Nebula header gradient -->
  <LinearGradientBrush x:Key="NebulaHeaderBrush" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="{StaticResource VoidColor}" Offset="0"/>
    <GradientStop Color="{StaticResource NebulaColor}" Offset="0.7"/>
    <GradientStop Color="{StaticResource NebulaBrightColor}" Offset="1"/>
  </LinearGradientBrush>

  <!-- Metallic capsule button -->
  <Style x:Key="MetalButton" TargetType="Button">
    <Setter Property="Foreground" Value="{StaticResource ChromeBrush}"/>
    <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
    <Setter Property="Padding" Value="12,6"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="b" CornerRadius="3" BorderBrush="{StaticResource GoldBrush}" BorderThickness="1">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF3C3C50" Offset="0"/>
                <GradientStop Color="#FF1F1638" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="b" Property="Background" Value="{StaticResource NebulaBrightColor}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
