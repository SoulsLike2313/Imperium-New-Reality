{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://imperium.local/schemas/block_manifest.schema.json",
  "title": "Block Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "block_id",
    "block_type",
    "owner_organ",
    "purpose",
    "read_first_files",
    "protected_zones",
    "editable_zones",
    "runtime_zones",
    "input_contracts",
    "output_contracts",
    "scripts_or_tools",
    "receipts",
    "matrices",
    "memory_refs",
    "pain_memory_refs",
    "success_memory_refs",
    "improvement_request_refs",
    "validation_gates",
    "context_budget",
    "forbidden_claims"
  ],
  "properties": {
    "block_id": {
      "type": "string",
      "pattern": "^[A-Z0-9_\\-]{6,}$"
    },
    "block_type": {
      "type": "string"
    },
    "owner_organ": {
      "type": "string"
    },
    "purpose": {
      "type": "string",
      "minLength": 8
    },
    "read_first_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "protected_zones": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "editable_zones": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "runtime_zones": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "input_contracts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "output_contracts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scripts_or_tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "receipts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "matrices": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "memory_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pain_memory_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "success_memory_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "improvement_request_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "context_budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_file_count",
        "max_character_count"
      ],
      "properties": {
        "max_file_count": {
          "type": "integer",
          "minimum": 1
        },
        "max_character_count": {
          "type": "integer",
          "minimum": 100
        }
      }
    },
    "forbidden_claims": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
