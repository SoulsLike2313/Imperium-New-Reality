{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ORGAN_DIALOGUE_REQUEST_V0_1",
  "type": "object",
  "required": [
    "schema_id",
    "request_id",
    "task_id",
    "source_actor",
    "target_organ",
    "purpose",
    "question_set",
    "context_refs",
    "allowed_response_mode",
    "claim_boundary"
  ],
  "properties": {
    "schema_id": {
      "const": "ORGAN_DIALOGUE_REQUEST_V0_1"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "source_actor": {
      "type": "string",
      "minLength": 1
    },
    "target_organ": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "question_set": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "context_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowed_response_mode": {
      "enum": [
        "FOUNDATION_DETERMINISTIC_FILE_BACKED_ONLY"
      ]
    },
    "claim_boundary": {
      "type": "string",
      "pattern": "foundation-only|foundation_only|FOUNDATION"
    },
    "created_at_utc": {
      "type": "string"
    }
  }
}
