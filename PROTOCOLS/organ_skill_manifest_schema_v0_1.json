{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "skill_id",
    "skill_name",
    "status"
  ],
  "properties": {
    "skill_id": {
      "type": "string"
    },
    "skill_name": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "outputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
