{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "route_id",
    "task_id",
    "route_sequence"
  ],
  "properties": {
    "route_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "route_sequence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
