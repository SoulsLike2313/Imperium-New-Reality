# Generated dependency/cache folders are not part of the New Reality source commit.
node_modules/
__pycache__/
.pytest_cache/
.taskpack_import_tmp/
*.pyc
*.pyo
.venv/
venv/

# Local operator route configs and old-prefix residue stay outside source commits.
ORGANS/ASTRONOMICON/SKILLS/TASKPACK_REGISTRATION_SKILL/contour_route_config.json
IMPERIUM_NEW_GENERATION/

# Post-work archive payloads stay local; commit their index cards and hashes instead.
REPORTS/**/ADMINISTRATUM_BUNDLE_CONTRACT_RECEIPT.zip

# Imperial IDE candidate runtimes are local-only and never enter validated pushes.
ORGANS/IMPERIAL_IDE/WARP/runtime/
ORGANS/IMPERIAL_IDE/WARP/RUNTIME/
ORGANS/IMPERIAL_IDE/WORKBENCH/SERVITORS/runtime/
ORGANS/IMPERIAL_IDE/WORKBENCH/SERVITORS/queues/
ORGANS/IMPERIAL_IDE/WORKBENCH/SERVITORS/results/
ORGANS/IMPERIAL_IDE/WORKBENCH/SERVITORS/_queue/
ORGANS/IMPERIAL_IDE/WORKBENCH/runtime/
ORGANS/IMPERIAL_IDE/METAOS/runtime/
ORGANS/IMPERIAL_IDE/METAOS/chronicles/runtime/
