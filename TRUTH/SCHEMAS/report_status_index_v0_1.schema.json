{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "REPORT_STATUS_INDEX_V0_1",
  "type": "object",
  "required": [
    "schema_id",
    "task_id",
    "generated_at_utc",
    "entries",
    "allowed_status_values"
  ],
  "properties": {
    "schema_id": {
      "const": "REPORT_STATUS_INDEX_V0_1"
    },
    "task_id": {
      "type": "string"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "report_path",
          "validator_report_path",
          "final_owner_report_path",
          "final_receipt_path",
          "status",
          "evidence_refs",
          "freshness",
          "notes"
        ],
        "properties": {
          "task_id": {
            "type": "string"
          },
          "report_path": {
            "type": "string"
          },
          "validator_report_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "final_owner_report_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "final_receipt_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "enum": [
              "PASS",
              "PASS_WITH_WARN",
              "WARN",
              "BLOCK",
              "UNKNOWN",
              "MISSING",
              "PARTIAL",
              "FOUNDATION_ONLY"
            ]
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "freshness": {
            "enum": [
              "CURRENT",
              "STALE",
              "UNKNOWN"
            ]
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "allowed_status_values": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "summary": {
      "type": "object"
    }
  }
}
