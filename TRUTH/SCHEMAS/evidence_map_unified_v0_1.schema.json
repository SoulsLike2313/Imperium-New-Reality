            "type": "string"
          },
          "source_kind": {
            "type": "string"
          },
          "task_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "phase_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "string"
          },
          "freshness": {
            "enum": [
              "CURRENT",
