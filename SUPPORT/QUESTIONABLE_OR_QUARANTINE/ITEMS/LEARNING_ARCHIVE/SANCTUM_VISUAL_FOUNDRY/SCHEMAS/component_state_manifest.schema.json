{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Component State Manifest",
  "type": "object",
  "required": ["components"],
  "properties": {
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "states"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "states": {"type": "array", "items": {"type": "string"}},
          "notes": {"type": "string"}
        }
      }
    }
  }
}
