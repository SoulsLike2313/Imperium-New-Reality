{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Step Proof Record",
  "type": "object",
  "required": [
    "task_id",
    "step_id",
    "claim",
    "basis",
    "risk",
    "scope",
    "proof_plan",
    "action",
    "evidence",
    "self_verdict",
    "timestamp_utc"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "step_id": {
      "type": "string"
    },
    "claim": {
      "type": "string"
    },
    "basis": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proof_plan": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "action": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "self_verdict": {
      "type": "string",
      "enum": [
        "PROVED",
        "STRONG",
        "PLAUSIBLE",
        "UNKNOWN",
        "FAILED",
        "FAKE_GREEN_RISK"
      ]
    },
    "limitations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "timestamp_utc": {
      "type": "string"
    }
  }
}