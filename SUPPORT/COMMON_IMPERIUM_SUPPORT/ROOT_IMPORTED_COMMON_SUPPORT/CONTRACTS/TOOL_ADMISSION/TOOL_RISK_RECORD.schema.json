{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TOOL_RISK_RECORD",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "risk_id",
    "task_id",
    "tool_slug",
    "linked_candidate_id",
    "risk_category",
    "severity",
    "risk_summary",
    "mitigation_plan",
    "proof_required_before_approval",
    "owner_gate_required",
    "recommended_state_if_unproven",
    "foundation_only",
    "created_at_utc"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1"
    },
    "risk_id": {
      "type": "string",
      "pattern": "^TRISK-[0-9]{3}$"
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "tool_slug": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-/]+$"
    },
    "linked_candidate_id": {
      "type": "string",
      "pattern": "^TCAND-[0-9]{3}$"
    },
    "risk_category": {
      "type": "string",
      "enum": [
        "SUPPLY_CHAIN",
        "SECURITY",
        "REPRODUCIBILITY",
        "MAINTENANCE",
        "COMPLEXITY",
        "PERFORMANCE",
        "DX"
      ]
    },
    "severity": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "CRITICAL"
      ]
    },
    "risk_summary": {
      "type": "string",
      "minLength": 1
    },
    "mitigation_plan": {
      "type": "string",
      "minLength": 1
    },
    "proof_required_before_approval": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "owner_gate_required": {
      "type": "boolean"
    },
    "recommended_state_if_unproven": {
      "type": "string",
      "enum": [
        "CANDIDATE_ONLY",
        "AVAILABLE_ON_HOST_UNVERIFIED_FOR_IMPERIUM",
        "AVAILABLE_ON_HOST_VERIFIED_BASIC",
        "DEFERRED_NEEDS_OWNER",
        "DEFERRED_NEEDS_ADMISSION_TASK",
        "BLOCKED_BY_RISK",
        "APPROVED_FOR_FUTURE_INSTALL_TASK",
        "APPROVED_FOR_READ_ONLY_USE",
        "INSTALLED_AND_REGISTERED"
      ]
    },
    "foundation_only": {
      "type": "boolean"
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    }
  }
}
