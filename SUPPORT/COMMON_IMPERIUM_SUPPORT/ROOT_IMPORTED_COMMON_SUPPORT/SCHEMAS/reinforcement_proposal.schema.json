{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "proposal_id",
    "type",
    "why_now",
    "first_use_case",
    "risk",
    "admission_mode"
  ],
  "properties": {
    "proposal_id": {
      "type": "string"
    },
    "type": {
      "enum": [
        "skill_api_tool_candidate",
        "matrix_gate_improvement",
        "cost_context_output_optimization"
      ]
    },
    "why_now": {
      "type": "string"
    },
    "first_use_case": {
      "type": "string"
    },
    "risk": {
      "type": "string"
    },
    "admission_mode": {
      "type": "string"
    }
  }
}

